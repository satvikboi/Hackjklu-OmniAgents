# ============================================
# OmniAgent - Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# ============================================
# Backend Configuration
# ============================================

# Server Settings
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# CORS Origins (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Upload directory for files
UPLOAD_DIR=./uploads

# ============================================
# AI / LLM Configuration
# ============================================

# Groq API Key - Get from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Confidence threshold for agent outputs (1-10 scale)
CONFIDENCE_THRESHOLD=7.0

# ============================================
# Shopify API Configuration
# ============================================

# Shopify Store Details
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=your_shopify_access_token
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret

# Shopify Webhook Secret (for verifying webhooks)
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret

# ============================================
# WhatsApp Business API Configuration
# ============================================

# Meta/WhatsApp Business API
WHATSAPP_API_TOKEN=your_whatsapp_api_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# Test Phone Numbers (for development)
OWNER_PHONE=+919876543210

# ============================================
# Gmail API Configuration
# ============================================

# Gmail API credentials
GMAIL_API_KEY=your_gmail_api_key
GMAIL_SENDER_EMAIL=your-store@example.com

# For OAuth2 (production)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ============================================
# Instagram Graph API Configuration
# ============================================

# Instagram Business Account
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_id

# ============================================
# Google Sheets API Configuration
# ============================================

# Google Sheets
GOOGLE_SHEETS_API_KEY=your_sheets_api_key
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Spreadsheet IDs
GOOGLE_SHEETS_ID=your_spreadsheet_id

# ============================================
# Notion API Configuration
# ============================================

# Notion Integration Token
NOTION_API_TOKEN=your_notion_integration_token

# Notion Database IDs
NOTION_DB_ID=your_database_id
NOTION_CONTENT_DB_ID=your_content_calendar_db_id
NOTION_REPORTS_DB_ID=your_reports_db_id
NOTION_ADS_DB_ID=your_ad_recommendations_db_id

# ============================================
# Brave Search API Configuration
# ============================================

# Brave Search API Key - Get from https://brave.com/search/api/
BRAVE_API_KEY=your_brave_api_key

# ============================================
# Meta Ads API Configuration
# ============================================

# Meta/Facebook Ads
META_ACCESS_TOKEN=your_meta_access_token
META_AD_ACCOUNT_ID=your_ad_account_id
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# ============================================
# Google My Business API
# ============================================

# Google My Business
GMB_API_KEY=your_gmb_api_key
GMB_LOCATION_ID=your_location_id

# ============================================
# Database Configuration
# ============================================

# ChromaDB
CHROMADB_PATH=./chroma_db

# PostgreSQL (for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/omniagent

# SQLite (for development)
DATABASE_URL=sqlite:///./omniagent.db

# ============================================
# Frontend Configuration
# ============================================

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# Business Configuration (Demo/Defaults)
# ============================================

# Default Business Settings
DEFAULT_BUSINESS_NAME=My Store
DEFAULT_BUSINESS_INDUSTRY=Clothing
DEFAULT_BUSINESS_CITY=Jaipur
DEFAULT_BUSINESS_STATE=Rajasthan

# Supplier Information
SUPPLIER_EMAIL=supplier@example.com
SUPPLIER_NAME=Main Supplier

# Owner Information
OWNER_EMAIL=owner@example.com
OWNER_NAME=Store Owner

# ============================================
# Feature Flags
# ============================================

# Enable/Disable Features
ENABLE_WEBHOOKS=true
ENABLE_SCHEDULER=true
ENABLE_MOCK_MODE=false

# ============================================
# Development/Testing
# ============================================

# Debug Mode
DEBUG=false
LOG_LEVEL=INFO

# Test Mode (uses mock data instead of real APIs)
TEST_MODE=false

# ============================================
# Security
# ============================================

# JWT Secret (generate a secure random string)
JWT_SECRET=your_jwt_secret_key_here_min_32_chars

# Encryption Key (for sensitive data)
ENCRYPTION_KEY=your_encryption_key_here

# ============================================
# Rate Limiting
# ============================================

# API Rate Limits
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600
